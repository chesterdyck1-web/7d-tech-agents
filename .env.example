# Copy this file to .env.local and fill in every value.
# The server will refuse to start if any required var is missing.

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # console.anthropic.com → API Keys

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                   # @BotFather → /newbot
TELEGRAM_CHESTER_CHAT_ID=             # Message bot → getUpdates API

# ─── Google (one OAuth credential covers all Google services) ─────────────────
GOOGLE_CLIENT_ID=                     # GCP → APIs & Services → OAuth 2.0 Client IDs
GOOGLE_CLIENT_SECRET=                 # GCP → APIs & Services → OAuth 2.0 Client IDs
GOOGLE_REFRESH_TOKEN=                 # One-time OAuth flow (helper script provided in Phase 1)
GOOGLE_SHEETS_ID=                     # From spreadsheet URL: /d/{THIS_PART}/edit
GOOGLE_PLACES_API_KEY=                # GCP → APIs & Services → Credentials → API Key

# ─── Vapi ─────────────────────────────────────────────────────────────────────
VAPI_API_KEY=                         # dashboard.vapi.ai → API Keys
VAPI_ASSISTANT_ID=                    # dashboard.vapi.ai → Assistants → created in Phase 2

# ─── Make.com ─────────────────────────────────────────────────────────────────
MAKE_API_KEY=                         # Make.com → Profile → API
MAKE_TEAM_ID=                         # From Make.com URL when viewing your team
MAKE_WEBHOOK_SECRET=                  # Choose any random string — set same value in Make.com scenario

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                    # dashboard.stripe.com → Developers → API Keys
STRIPE_WEBHOOK_SECRET=                # dashboard.stripe.com → Developers → Webhooks → signing secret

# ─── OpusClip ─────────────────────────────────────────────────────────────────
OPUS_CLIP_API_KEY=                    # app.opus.pro → Settings → API

# ─── Publer ───────────────────────────────────────────────────────────────────
PUBLER_API_KEY=                       # publer.io → Settings → API

# ─── GitHub (Builder Agent deploys) ──────────────────────────────────────────
GITHUB_TOKEN=                         # GitHub → Settings → Developer Settings → Personal access tokens
GITHUB_REPO_OWNER=                    # Your GitHub username
GITHUB_REPO_NAME=7d-tech-agents       # The repo name

# ─── Security ─────────────────────────────────────────────────────────────────
APPROVAL_SECRET=                      # Run: openssl rand -hex 32
CRON_SECRET=                          # Run: openssl rand -hex 32

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                  # e.g. https://7d-tech.vercel.app (no trailing slash)
